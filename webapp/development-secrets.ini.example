# Copy this file to development-secrets.ini and fill in your values
# DO NOT commit development-secrets.ini to version control!

[gemini]
# =============================================================================
# GOOGLE GEMINI API (for art generation)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Requires a Google account. Free tier available with rate limits.
api_key =

[obsidian_portal]

# =============================================================================
# BROWSER SESSION APPROACH (WORKING)
# =============================================================================
# Since the OAuth API is broken, we simulate browser requests. To set this up:
#
# 1. Log into Obsidian Portal in Chrome
# 2. Open DevTools (F12) -> Network tab
# 3. Navigate to your campaign's characters page
# 4. Click on any request to obsidianportal.com
# 5. In the Headers tab, find "Cookie:" and copy the entire value
# 6. For authenticity_token: View Page Source and search for "csrf-token"
#    or look for a hidden input named "authenticity_token"
#
# These values expire periodically - you'll need to update them when uploads fail.

session_cookie = paste_your_full_cookie_header_here
authenticity_token = your_csrf_token_here

# Asset folder ID for image uploads - find it in the Network tab when
# manually uploading an image (look for the asset_folder_id parameter)
asset_folder_id =

# =============================================================================
# OAUTH API CREDENTIALS (CURRENTLY BROKEN - January 2025)
# =============================================================================
# The Obsidian Portal API returns 403 errors. These fields are preserved
# in case the API is restored in the future.
#
# Get these from http://www.obsidianportal.com/oauth/clients/new
consumer_key =
consumer_secret =

# Run authorize_op.py to obtain these (once API is working)
access_token =
access_token_secret =

# Campaign UUID (find via API or in network requests)
campaign_id =

[discord]
# =============================================================================
# DISCORD OAUTH (for login)
# =============================================================================
# Create a Discord application: https://discord.com/developers/applications
#   1. New Application → name it.
#   2. OAuth2 → Redirects → add BOTH:
#        http://127.0.0.1:8080/auth/callback
#        https://l7r-gm-assistant.fly.dev/auth/callback
#   3. OAuth2 → copy Client ID below.
#   4. OAuth2 → "Reset Secret" → copy the Client Secret below.
# The app only requests the `identify` scope (basic profile, no email/guilds).
client_id =
client_secret =

[auth]
# Random secret used to HMAC-sign session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
session_secret =

[discord_whitelist]
# Discord IDs allowed to log in. Membership here grants the 'player' role:
# can use the character generator and upload to Obsidian Portal.
# Format: <discord_id> = <display name>
# Get a user's Discord ID by enabling Developer Mode in Discord (Advanced
# settings) then right-clicking their name and "Copy User ID".
# Example:
#   282617191147241474 = Chris R.

[gm_whitelist]
# Discord IDs granted the 'gm' role on top of 'player'. GMs see the
# "Save to archive" button on chargen and can hit GM-only routes.
# A GM does NOT need a separate entry in [discord_whitelist] — membership
# here is sufficient for login (gm ≥ player).
# Format: <discord_id> = <display name>
# Example:
#   183026066498125825 = Eli
