{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/gm-assistant/scripts/clone-sync-hooks.sh prompt",
            "timeout": 60,
            "statusMessage": "Syncing session clone with main..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/gm-assistant/scripts/clone-sync-hooks.sh pretool",
            "timeout": 30
          }
        ]
      }
    ]
  }
}