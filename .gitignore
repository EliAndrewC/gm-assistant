__pycache__
*.lock
.env
.coverage

# Local virtualenv + test runner caches.
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Per-machine Claude Code permission grants - gitignored by convention.
.claude/settings.local.json

# Isolated per-session working clones for parallel Claude sessions (see CLAUDE.md "Parallel
# sessions"). Each is a full `git clone` of this repo, kept out of git so the two working trees
# never cross-contaminate. Lives on the host mount, so it survives a container rebuild.
.clones/

# /diagram map artifacts are DERIVED from their .gen.py + .json (the real source, kept in
# git) - both the .png render and the .svg it renders from. A to-scale village .svg is tens
# of MB (one primitive per crop row / grass tuft), so tracking them bloated the working tree
# and grew git history every diagram commit. They are regenerated on demand, so both are
# gitignored. Regenerate with `python3 .claude/skills/diagram/pool/<map>.gen.py`.
.claude/skills/diagram/pool/*.png
.claude/skills/diagram/pool/*.svg
# ...but the HAND-AUTHORED Mode A compound plans (magistracies, drafts) have NO generator - they ARE the
# source, KB-sized, not regenerable - so they stay tracked. Add any new hand-authored pool SVG here.
!.claude/skills/diagram/pool/ochiba-magistracy.svg
!.claude/skills/diagram/pool/ochiba-recomposed-draft.svg
!.claude/skills/diagram/pool/county-magistracy-draft.svg
!.claude/skills/diagram/pool/hayakawa-magistracy.svg

# Spoiler-sensitive /dream scenes: the local tier is the GM's disk only, never committed.
# The public tier (.claude/skills/dream/pool/) stays tracked; see that skill's SKILL.md.
.claude/skills/dream/pool-local/

# GNOME atomic-save temp files (a stray one was once committed); never track these.
.goutputstream-*

# Generated org chart - rebuild with `webapp/orgchart.py --format png` rather than tracking it.
webapp/orgchart.png
