__pycache__
*.lock
.env
.coverage

# Local virtualenv + test runner caches.
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Per-machine Claude Code permission grants - gitignored by convention.
.claude/settings.local.json

# Isolated per-session working clones for parallel Claude sessions (see CLAUDE.md "Parallel
# sessions"). Each is a full `git clone` of this repo, kept out of git so the two working trees
# never cross-contaminate. Lives on the host mount, so it survives a container rebuild.
.clones/

# Rendered /diagram map PNGs are regenerable from their .gen.py/.svg/.json (kept in git),
# so they are not tracked - this is what keeps them out of git history. Regenerate with
# `python3 .claude/skills/diagram/pool/<map>.gen.py`.
.claude/skills/diagram/pool/*.png

# Spoiler-sensitive /dream scenes: the local tier is the GM's disk only, never committed.
# The public tier (.claude/skills/dream/pool/) stays tracked; see that skill's SKILL.md.
.claude/skills/dream/pool-local/

# GNOME atomic-save temp files (a stray one was once committed); never track these.
.goutputstream-*

# Generated org chart - rebuild with `webapp/orgchart.py --format png` rather than tracking it.
webapp/orgchart.png
