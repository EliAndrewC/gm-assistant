__pycache__
*.lock
.env
.coverage

# Local virtualenv + test runner caches.
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Per-machine Claude Code permission grants - gitignored by convention.
.claude/settings.local.json

# Isolated per-session working clones for parallel Claude sessions (see CLAUDE.md "Parallel
# sessions"). Each is a full `git clone` of this repo, kept out of git so the two working trees
# never cross-contaminate. Lives on the host mount, so it survives a container rebuild.
.clones/

# /diagram pool is foldered BY SUBJECT so tracking is per-folder (no per-file exemptions):
#  - GENERATED settlement maps (Mode B: villages/hamlets/towns/provincial-cities) derive their
#    .svg + .png from a .gen.py + .json - a to-scale village .svg is tens of MB (one primitive per
#    crop row), so both derived artifacts are ignored and regenerated on demand
#    (`python3 .claude/skills/diagram/pool/<type>/<map>.gen.py`).
#  - HAND-AUTHORED Mode A compound plans (magistracies/) have NO generator - the .svg IS the source,
#    KB-sized - so it stays tracked; only its .png render is ignored.
#  - regressions/ holds tracked fixture .svgs (no ignore line -> tracked).
# A NEW settlement type would add its two lines here; a new magistracy .svg is auto-tracked.
.claude/skills/diagram/pool/villages/*.svg
.claude/skills/diagram/pool/villages/*.png
.claude/skills/diagram/pool/hamlets/*.svg
.claude/skills/diagram/pool/hamlets/*.png
.claude/skills/diagram/pool/towns/*.svg
.claude/skills/diagram/pool/towns/*.png
.claude/skills/diagram/pool/provincial-cities/*.svg
.claude/skills/diagram/pool/provincial-cities/*.png
.claude/skills/diagram/pool/magistracies/*.png

# Spoiler-sensitive /dream scenes: the local tier is the GM's disk only, never committed.
# The public tier (.claude/skills/dream/pool/) stays tracked; see that skill's SKILL.md.
.claude/skills/dream/pool-local/

# GNOME atomic-save temp files (a stray one was once committed); never track these.
.goutputstream-*

# Generated org chart - rebuild with `webapp/orgchart.py --format png` rather than tracking it.
webapp/orgchart.png
